# Copy this file to `.env` and fill in the real values for your machine/team.

FLASK_SECRET_KEY=replace-with-a-real-secret-key

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=replace-with-db-password
DB_NAME=luxemotordb

# Set to false when the shared Raspberry Pi database is already created.
DB_CREATE_DATABASE=true

# Set to false to reduce SQL logging noise.
DB_ECHO=true
